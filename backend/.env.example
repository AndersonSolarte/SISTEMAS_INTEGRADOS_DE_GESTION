# Gemini (Google Generative AI) - usado para sugerir indicadores a partir de la actividad.
# Obtener en https://aistudio.google.com/app/apikey (plan gratis: 1500 req/dia).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# IA para sugerir indicadores. Valores: auto, openai, gemini.
# OpenAI usa API billing independiente de ChatGPT Plus/Premium.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
